<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary"
        android:elevation="4dp"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        app:popupTheme="@style/ThemeOverlay.AppCompat.Light"
        app:title="@string/app_name" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingLeft="20dp"
        android:paddingRight="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="12dp">

        <!-- Garage -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_garage"
                android:contentDescription="@string/garage_label" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/garage_label"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginStart="10dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/openButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:minHeight="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="@string/open_button"
                android:textSize="12sp"
                android:textColor="@color/white"
                app:backgroundTint="@color/button_open"
                app:cornerRadius="8dp"
                app:icon="@drawable/ic_arrow_up"
                app:iconSize="14dp"
                app:iconPadding="4dp"
                app:iconGravity="start" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/closeButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:minHeight="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="@string/close_button"
                android:textSize="12sp"
                android:textColor="@color/white"
                android:layout_marginStart="8dp"
                app:backgroundTint="@color/button_close"
                app:cornerRadius="8dp"
                app:icon="@drawable/ic_arrow_down"
                app:iconSize="14dp"
                app:iconPadding="4dp"
                app:iconGravity="start" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/text_secondary"
            android:alpha="0.2"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp" />

        <!-- Espresso -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_espresso"
                android:contentDescription="@string/espresso_label" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/espresso_label"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginStart="10dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/espressoOnButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:minHeight="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="@string/on_button"
                android:textSize="12sp"
                android:textColor="@color/white"
                app:backgroundTint="@color/button_open"
                app:cornerRadius="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/espressoOffButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:minHeight="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="@string/off_button"
                android:textSize="12sp"
                android:textColor="@color/white"
                android:layout_marginStart="8dp"
                app:backgroundTint="@color/button_close"
                app:cornerRadius="8dp" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:gravity="center" />

    </LinearLayout>

    <TextView
        android:id="@+id/versionText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="10sp"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:paddingTop="4dp"
        android:paddingBottom="6dp" />

</LinearLayout>
